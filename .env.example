# ── Telegram ───────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Model Provider ─────────────────────────────────────────────────────────
# Options: gemini_apikey | vertex | litellm
MODEL_PROVIDER=gemini_apikey

# For gemini_apikey mode (Google AI Studio):
GEMINI_API_KEY=your_gemini_api_key_here

# For vertex mode (Google Cloud Vertex AI):
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=global
# GOOGLE_GENAI_USE_VERTEXAI=true

# For litellm mode (any model):
# LITELLM_MODEL=anthropic/claude-sonnet-4-20250514

# ── Database ───────────────────────────────────────────────────────────────
# Defaults to local SQLite if not set.
# For cloud deployment, use a PostgreSQL connection string:
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Scoring ────────────────────────────────────────────────────────────────
# Alert threshold score (0-100). Default is 70.
# ALERT_SCORE_THRESHOLD=70
